# ============================================
# WordPress 全自動リライトツール 設定
# ============================================

# Gemini API キー（必須）
# Google AI Studio で取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini モデル設定（任意）
GEMINI_TEXT_MODEL=gemini-2.5-flash-preview-05-20
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ログレベル（任意: error, warn, info, debug）
LOG_LEVEL=info

# Web UI 認証（VPS運用時に設定推奨）
WEB_USER=
WEB_PASSWORD=
